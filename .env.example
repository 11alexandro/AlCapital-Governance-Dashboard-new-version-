# GEMINI_API_KEY: Secret key required for authorizing server-side Gemini AI calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The base URL where this application is deployed.
# Used for public asset references, absolute paths, and web callbacks.
APP_URL="YOUR_APP_URL"

# MongoDB Database Connection String
# Leave empty to utilize integrated local file-system fallback database.
MONGODB_URI=

# Port configuration (Hardcoded to 3000 in sandbox containers)
PORT=3000

# Ethereum RPC Provider endpoint (used in ethers.js connection fallback)
RPC_URL="https://cloudflare-eth.com"

# Set to true when running in Google AI Studio or other sandboxed environments to suppress Vite HMR WebSocket errors
DISABLE_HMR=true

